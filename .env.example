# Wrike permanent access token (Profile -> Apps & Integrations -> API)
WRIKE_TOKEN=

# Optional: override the Wrike base URL (e.g. https://app-us2.wrike.com/api/v4).
# WARNING: the bearer token (WRIKE_TOKEN) is sent in an Authorization header
# to whatever URL you configure here. Do not point this at hosts you do not trust.
# WRIKE_BASE_URL=https://www.wrike.com/api/v4

# Name of the Wrike custom field that holds the recipient UEI (case-insensitive)
WRIKE_UEI_FIELD_NAME=uei

# Optional: override USASpending base URL
# USASPENDING_BASE_URL=https://api.usaspending.gov/api/v2

# HTTP timeout in seconds
REQUEST_TIMEOUT=30

# ---------------------------------------------------------------------------
# Weekly digest (used by `noa-finder weekly-digest` and the GitHub Actions cron)
# ---------------------------------------------------------------------------

# Wrike space ID containing client tasks (used by the GitHub Actions workflow)
WRIKE_SPACE_ID=

# Slack incoming webhook URL — leave blank to skip Slack delivery
SLACK_WEBHOOK_URL=

# SMTP for digest emails — leave SMTP_HOST blank to skip email delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=
EMAIL_TO=                # comma-separated recipients

# Timezone used in the digest header (zoneinfo name)
DIGEST_TIMEZONE=America/New_York

# Send a digest even when zero new awards were created (heartbeat)
DIGEST_SEND_WHEN_EMPTY=true
